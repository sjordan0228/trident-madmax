[output_pin nevermore]
pin: PF7
value: 0
shutdown_value: 0

[heater_fan exhaust_fan]
##  Exhaust fan - FAN3
pin: PF9
#tachometer_pin: PF8
max_power: 1.0
shutdown_speed: 0.0
